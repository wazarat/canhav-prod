# CanHav frontend — copy to .env.local for local dev; set the same keys on Vercel for production.
# Arbitrum Sepolia testnet only.

# --- Auth (Privy) ---
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Optional: re-enable ZeroDev kernel accounts for agent mint (default off)
USE_ZERODEV=false

# --- Admin panel (Supabase; /admin only — independent of Privy) ---
# Provision a Supabase project, create the `admins` table (see lib/auth/admins.sql),
# and add allowed emails as rows. Magic-link login lives at /admin/login.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# APPROVAL_TOKEN also authorizes the admin diagnostics/content APIs (Bearer).
APPROVAL_TOKEN=

# --- On-chain identity (ZeroDev + ERC-8004) ---
ZERODEV_RPC=
IDENTITY_REGISTRY_ADDRESS=
SECURITY_REGISTRY_ADDRESS=
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# --- tCNHV credits (required for credits wallet UI + signup grant) ---
TCNHV_TOKEN_ADDRESS=
FACTORY_DEPLOYER_PRIVATE_KEY=
# Optional: one-time signup grant amount (human units, default 10000)
STARTING_TCNHV=10000
AGENT_FACTORY_ADDRESS=
AGENT_LEDGER_IMPL_ADDRESS=

# --- Collab (optional) ---
COLLAB_REGISTRY_ADDRESS=
COLLAB_AGREEMENT_ADDRESS=
USDC_ASSET_ADDRESS=

# --- Memory + LLM ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
OPENAI_API_KEY=
# or AI_GATEWAY_API_KEY=

# --- Agent Lab admin (provisioning panel visibility) ---
# Comma-separated Privy-linked emails and/or Privy DIDs allowed to see the
# provisioning readiness panel on /agents. Leave empty to hide it for everyone
# without a Supabase /admin session.
ADMIN_EMAILS=
ADMIN_USER_IDS=

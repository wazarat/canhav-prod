# Copy to `agent-service/.env` and fill in. `.env` is gitignored.
# NETWORK: Arbitrum Sepolia ONLY (chainId 421614). Testnet only.

# ZeroDev project endpoints for Arbitrum Sepolia (bundler + paymaster).
# Create a project at https://dashboard.zerodev.app (select Arbitrum Sepolia).
ZERODEV_RPC=https://rpc.zerodev.app/api/v3/<PROJECT_ID>/chain/421614
ZERODEV_PROJECT_ID=

# Public RPC for read calls (gate checks, event parsing).
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Deployed registry addresses (from `contracts` Deploy.s.sol output).
IDENTITY_REGISTRY_ADDRESS=
SECURITY_REGISTRY_ADDRESS=

# Optional: Arbiscan API key for source-verification gating (off-chain check).
ARBISCAN_API_KEY=

# --- Frontend agent layer (Next.js) ----------------------------------------
# The web app dynamically imports this package for the ERC-8004 spawn bridge
# (frontend/app/api/agent/spawn). When deployed on Vercel, the SAME on-chain
# vars above (ZERODEV_RPC, IDENTITY_REGISTRY_ADDRESS, SECURITY_REGISTRY_ADDRESS)
# must be set as frontend project env vars — agent-service loadConfig() reads
# process.env. Additionally the browser passkey ceremony needs a public var:
#   NEXT_PUBLIC_ZERODEV_PASSKEY_SERVER=https://passkeys.zerodev.app/api/v3/<PROJECT_ID>
# and the research loop needs OPENAI_API_KEY (documented in backend/.env.example).

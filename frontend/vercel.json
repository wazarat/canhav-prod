{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "rm -rf node_modules/canhav-agent-service && npm install",
  "crons": [
    {
      "path": "/api/cron/refresh",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/agent-verdicts",
      "schedule": "0 7 * * *"
    }
  ]
}

# Copy to .env and fill in values (never commit .env)
# Deployer wallet — testnet only. Fund with Arbitrum Sepolia ETH before broadcast.

PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBISCAN_API_KEY=

# ---------------------------------------------------------------------------
# tCNHV token + Agent Factory/Ledger (DeployFactoryToken.s.sol)
# ---------------------------------------------------------------------------
# Inputs (optional): the ALREADY-DEPLOYED registries the new AgentFactory
# references. Leave unset to default to address(0) — they are forward-looking
# references for the deferred collab hook and are not required to deploy.
IDENTITY_REGISTRY_ADDRESS=
COLLAB_REGISTRY_ADDRESS=

# Outputs: after running
#   forge script script/DeployFactoryToken.s.sol:DeployFactoryToken \
#     --rpc-url arbitrum_sepolia --broadcast --verify
# record the three logged addresses below (and mirror into the frontend env):
TCNHV_TOKEN_ADDRESS=
AGENT_FACTORY_ADDRESS=
AGENT_LEDGER_IMPL_ADDRESS=

# ---------------------------------------------------------------------------
# Frontend / server wiring (mirror into backend/.env + Vercel)
# ---------------------------------------------------------------------------
# The frontend reads TCNHV_TOKEN_ADDRESS + AGENT_FACTORY_ADDRESS (above) to
# auto-create ledgers on spawn, settle collab in tCNHV, record work, and show
# merit/faucet UI. FACTORY_DEPLOYER_PRIVATE_KEY is the platform OWNER key (same
# as PRIVATE_KEY here) — it signs the owner-only writes server-side
# (createLedger / setTransferAllowed / recordWork). TESTNET ONLY: it can mint
# tCNHV and must never be exposed to the client. Leave unset to no-op cleanly.
FACTORY_DEPLOYER_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Backfill existing agents (BackfillLedgers.s.sol) — comma-separated, aligned
# ---------------------------------------------------------------------------
# One entry per already-minted agent. Indices must line up across the three
# lists. The script skips agents that already have a ledger (idempotent) and
# allowlists each agent wallet for tCNHV transfers.
#   forge script script/BackfillLedgers.s.sol:BackfillLedgers \
#     --rpc-url arbitrum_sepolia --broadcast --slow
BACKFILL_AGENT_IDS=
BACKFILL_OWNERS=
BACKFILL_WALLETS=

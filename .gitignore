# ---------------------------------------------------------------------------
# CanHav Research .gitignore
# Per project governance: ALL Markdown (*.md) and Cursor rule (*.mdc) files are
# excluded from version control. The user maintains dev-notes locally only.
# ---------------------------------------------------------------------------

# Markdown & Cursor rules (governance requirement)
*.md
*.mdc

# Node / Next.js
node_modules/
.next/
out/
build/
dist/
.turbo/
*.tsbuildinfo
next-env.d.ts

# Environment / secrets (keep the committed template)
.env*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/

# Local data store (file-backed LocalAdapter; production uses Upstash Redis)
backend/data/store.json
# Agent memory fallback (offline dev only; production uses Upstash Redis)
backend/data/agent-store.json
# Passkey user + conversation fallbacks (offline dev only)
backend/data/user-store.json
backend/data/conversation-store.json
# Agent collaboration state fallbacks (offline dev only; production uses Upstash Redis)
backend/data/collab-payrefs.json
backend/data/collab-log.json
backend/data/collab-agreements.json
backend/data/collab-reviews.json
# User-authored skill fallback (offline dev only; production uses Upstash Redis)
backend/data/user-skills.json

# OS / editor
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/
.vercel

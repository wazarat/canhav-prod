# Copy to `.env` and fill in as needed. `.env` is gitignored.

# Storage backend: "local" (default, file-backed) or "dynamo"
DB_BACKEND=local

# Optional override for the local JSON store (defaults to backend/data/store.json)
# STORE_PATH=./data/store.json

# --- DynamoDB (Step 4 / production) ----------------------------------------
# AWS_REGION=us-east-1
# DYNAMODB_TABLE=canhav-research
# DYNAMODB_ENDPOINT_URL=http://localhost:8000   # only for DynamoDB Local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Live data overlays (Step 4) -------------------------------------------
# Free-tier keys only. Do NOT commit real keys. `.env` is gitignored.
# Used by backend/scripts/refresh_live.py (Alchemy supply/TVL overlays).
ALCHEMY_API_KEY=
# Dune is wired but not yet active (history is stubbed until query IDs exist).
DUNE_API_KEY=

# Alchemy Arbitrum RPC base (override only if you use a non-default network/host).
# ALCHEMY_ARBITRUM_BASE_URL=https://arb-mainnet.g.alchemy.com/v2

# CoinGecko address/price resolution (free, public API — no key required).
# Set a key only if you have a CoinGecko Pro/Demo plan and hit rate limits.
# COINGECKO_API_KEY=

# --- Approval API (Next route handler) -------------------------------------
# Shared secret for the restricted /staging "Approve" action. The Next route
# handler (frontend/app/api/approve/route.ts) reads this from backend/.env.
# Generate one, e.g.:  python3 -c "import secrets;print(secrets.token_urlsafe(32))"
APPROVAL_TOKEN=

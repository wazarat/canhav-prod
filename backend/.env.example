# Copy to `.env` and fill in as needed. `.env` is gitignored.

# Storage backend: "local" (default, file-backed) or "redis" (Upstash)
DB_BACKEND=local

# Optional override for the local JSON store (defaults to backend/data/store.json)
# STORE_PATH=./data/store.json

# --- Upstash Redis (DB_BACKEND=redis / production) -------------------------
# Connection string from the Upstash console (TLS). Used by redis-py on Render
# and by the local ops scripts when DB_BACKEND=redis.
REDIS_URL=
# Optional override for the hash key all items live under (default canhav:store)
# REDIS_STORE_KEY=canhav:store

# --- Live data overlays ----------------------------------------------------
# Free-tier keys only. Do NOT commit real keys. `.env` is gitignored.
#
# These keys power BOTH the daily cron (backend/scripts/refresh_live.py and
# frontend/app/api/cron/refresh) AND the live-on-render detail pages
# (frontend/lib/server/{alchemy,coingecko,dune}.ts read them via readSecret()).
#
# Local dev: putting them here (backend/.env) works; the Next server modules
# also read process.env, so `frontend/.env.local` (auto-loaded by Next, e.g. via
# `vercel env pull frontend/.env.local`) works too.
# Production: set these as Vercel project environment variables.
ALCHEMY_API_KEY=
# Dune powers the historical peg/TVL charts. Needs saved query IDs to exist
# (see frontend/lib/server/dune.ts DUNE_QUERY_IDS); fails soft until then.
DUNE_API_KEY=

# Alchemy Arbitrum RPC base (override only if you use a non-default network/host).
# ALCHEMY_ARBITRUM_BASE_URL=https://arb-mainnet.g.alchemy.com/v2

# CoinGecko market data + address/price resolution (free, public API — no key
# required). Set a key only if you have a CoinGecko Pro/Demo plan and hit rate
# limits (sent as the x-cg-demo-api-key header).
# COINGECKO_API_KEY=

# --- AI agent layer (Pillar 2 — Next route handlers) -----------------------
# Powers the in-platform research agent (frontend/app/api/agent). Read via
# readSecret() (process.env first, then this file). Production: set as a Vercel
# project environment variable. Without it, the agent UI shows "not configured".
OPENAI_API_KEY=
# Optional model override for the agent loop (default: gpt-4o-mini).
# OPENAI_AGENT_MODEL=gpt-4o-mini

# --- Approval API (Next route handler) -------------------------------------
# Shared secret for the restricted /staging "Approve" action. The Next route
# handler (frontend/app/api/approve/route.ts) reads this from backend/.env.
# Generate one, e.g.:  python3 -c "import secrets;print(secrets.token_urlsafe(32))"
APPROVAL_TOKEN=

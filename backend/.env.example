# CanHav shared secrets (gitignored at runtime — copy to backend/.env)
# Vercel: set the same keys in the project dashboard (Root Directory: frontend).

# --- Research store (Upstash) ---
KV_REST_API_URL=
KV_REST_API_TOKEN=
# TCP connection string for Python ingest/seed scripts (redis-py). NOT populated by
# `vercel env pull` when marked Sensitive — copy from Upstash → Connect → Redis.
REDIS_URL=
# Alternate Upstash names (either pair works for Next.js REST reads):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
REDIS_STORE_KEY=canhav:store

# --- OpenAI (research agent) ---
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-4o-mini

# --- Session signing (passkey login) ---
SESSION_SECRET=

# --- ERC-8004 (Arbitrum Sepolia only) ---
IDENTITY_REGISTRY_ADDRESS=
SECURITY_REGISTRY_ADDRESS=
# Stable public URL for minted agent tokenURIs (e.g. https://canhav.co)
CANHAV_PUBLIC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
ARBISCAN_API_KEY=

# --- Live data overlays (optional) ---
ALCHEMY_API_KEY=
ALCHEMY_ARBITRUM_BASE_URL=
ALCHEMY_ETH_BASE_URL=
DUNE_API_KEY=
CRON_SECRET=

# --- Chain-native lending overlays (optional) ---
TRONGRID_API_KEY=
HELIUS_API_KEY=

# --- Agent -> Dune verdict publishing (optional; lands dark until enabled) ---
# Dune team handle / namespace the verdict table lives under (your Dune username, e.g. wazarat).
# Full table path: dune.{DUNE_NAMESPACE}.canhav_agent_verdicts
DUNE_NAMESPACE=
# Set to "1" to allow agents to write verdict rows. Requires DUNE_API_KEY with Read/Write scope.
DUNE_WRITE_ENABLED=

# --- Contract deploy (contracts/.env — never commit PRIVATE_KEY) ---
# PRIVATE_KEY=

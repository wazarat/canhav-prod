# Copy to `contracts/.env` and fill in. `.env` is gitignored.
# NETWORK: Arbitrum Sepolia ONLY (chainId 421614). Testnet only.

# RPC endpoint for Arbitrum Sepolia (e.g. Alchemy / public RPC).
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Deployer key for `forge script ... --broadcast`. Use a throwaway TESTNET key.
# NEVER commit a real key. Prefer `--account` keystore over a raw key in prod.
PRIVATE_KEY=

# Arbiscan API key for source verification (`--verify`).
ARBISCAN_API_KEY=
